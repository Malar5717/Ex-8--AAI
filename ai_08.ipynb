        "import speech_recognition as sr\n",
        "\n",
        "r = sr.Recognizer()\n",
        "\n",
        "with sr.AudioFile(\"/content/Recording.wav\") as source:\n",
        "    audio_data = r.record(source)\n",
        "\n",
        "try:\n",
        "    text = r.recognize_google(audio_data)\n",
        "    print(\"You said:\", text)\n",
        "except Exception as e:\n",
        "    print(\"Error:\", e)"
      ]
    }
